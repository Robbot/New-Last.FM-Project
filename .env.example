# Last.fm API Configuration
# Copy this file to .env and fill in your credentials

# HOW TO GET A LAST.FM API KEY:
# 1. Go to: https://www.last.fm/api/account/create
# 2. Log in with your Last.fm account (or create one if you don't have one)
# 3. Fill out the API application form:
#    - Application name: Any name you want (e.g., "My Last.fm Stats")
#    - Application description: Optional, describe what you're building
# 4. Click "Create API account"
# 5. Copy the "API Key" (long alphanumeric string) and paste below
#
# Note: You don't need the "Shared Secret" for this application - only the API Key

LASTFM_API_KEY=your_api_key_here

# Your Last.fm username (the one you use to log into https://last.fm)
LASTFM_USERNAME=your_username_here

# Spotify API Configuration
# HOW TO GET SPOTIFY API CREDENTIALS:
# 1. Go to: https://developer.spotify.com/dashboard
# 2. Log in with your Spotify account
# 3. Click "Create App"
# 4. Fill out the app form:
#    - App name: Any name you want (e.g., "Last.fm Stats Playlists")
#    - App description: Optional
#    - Redirect URI: http://localhost:8001/spotify/callback (for local development)
# 5. Click "Save"
# 6. Copy the "Client ID" and "Client Secret" and paste below
#
# Note: You may need to add additional redirect URIs for production deployments

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8001/spotify/callback

# Playlist Generation Settings (optional)
# These settings control automatic playlist generation behavior

SPOTIFY_PLAYLIST_AUTO_GENERATE=false
SPOTIFY_PLAYLIST_SCHEDULE=weekly  # daily, weekly, monthly
SPOTIFY_PLAYLIST_FORGOTTEN_DAYS=180  # Days since last play for "forgotten" playlists
SPOTIFY_PLAYLIST_TOP_TRACKS_DAYS=30  # Days to look back for "top tracks" playlists
SPOTIFY_PLAYLIST_DEFAULT_LIMIT=50  # Default number of tracks in generated playlists
